{
  "name": "bharat-mandi-poc",
  "version": "0.1.0",
  "description": "Bharat Mandi POC - Farmer to Buyer workflow demonstration",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && xcopy /Y /I src\\shared\\database\\*.sql .build\\shared\\database\\ && xcopy /Y /I src\\features\\crop-diagnosis\\data\\knowledge-base\\*.json .build\\features\\crop-diagnosis\\data\\knowledge-base\\",
    "start": "node .build/index.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "deploy:build": "npm run build && npm run deploy",
    "test": "jest --config scripts/jest.config.js",
    "test:watch": "jest --watch --config scripts/jest.config.js",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathPattern=\"\\.test\\.ts$\" --config scripts/jest.config.js",
    "test:pbt": "jest --testPathPattern=\"\\.pbt\\.test\\.ts$\" --config scripts/jest.config.js",
    "test:integration": "jest --testPathPattern=\"\\.integration\\.test\\.ts$\" --config scripts/jest.config.js",
    "test:db": "jest --testPathPattern=\"\\.db\\.test\\.ts$\" --config scripts/jest.config.js",
    "test:aws": "jest --testPathPattern=\"\\.aws\\.test\\.ts$\" --config scripts/jest.config.js",
    "test:e2e": "jest --testPathPattern=\"\\.e2e\\.test\\.ts$\" --config scripts/jest.config.js",
    "test:e2e:critical": "jest --testPathPattern=\"\\.e2e\\.test\\.ts$\" --testNamePattern=\"Critical\" --config scripts/jest.config.js",
    "test:coverage": "jest --coverage --config scripts/jest.config.js --coverageDirectory=docs/testing/coverage",
    "test:coverage:report": "jest --coverage --coverageReporters=html --config scripts/jest.config.js --coverageDirectory=docs/testing/coverage",
    "test:ci": "npm run test:unit && npm run test:pbt && npm run test:integration",
    "test:all": "npm run test:ci && npm run test:e2e",
    "migrate": "ts-node src/shared/database/migrate.ts",
    "db:setup": "ts-node src/shared/database/migrate.ts up",
    "db:rollback": "ts-node src/shared/database/migrate.ts rollback",
    "mongodb:setup": "ts-node src/shared/database/mongodb-setup.ts setup",
    "mongodb:test": "ts-node src/shared/database/mongodb-setup.ts test",
    "mongodb:stats": "ts-node src/shared/database/mongodb-setup.ts stats",
    "sqlite:setup": "ts-node src/shared/database/sqlite-setup.ts setup",
    "sqlite:test": "ts-node src/shared/database/sqlite-setup.ts test",
    "sqlite:stats": "ts-node src/shared/database/sqlite-setup.ts stats",
    "seed:farming-tips": "ts-node scripts/seed-farming-tips.ts",
    "test:kisan-mitra:live": "ts-node scripts/test-kisan-mitra-live.ts"
  },
  "keywords": [
    "agriculture",
    "marketplace",
    "escrow",
    "grading"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1003.0",
    "@aws-sdk/client-comprehend": "^3.998.0",
    "@aws-sdk/client-iam": "^3.998.0",
    "@aws-sdk/client-lex-runtime-v2": "^3.1000.0",
    "@aws-sdk/client-polly": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-sts": "^3.998.0",
    "@aws-sdk/client-transcribe": "^3.1000.0",
    "@aws-sdk/client-translate": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/sequelize": "^4.28.20",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-backend": "^3.0.2",
    "i18next-http-middleware": "^3.9.2",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.38",
    "mongoose": "^8.23.0",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "pg": "^8.18.0",
    "pgvector": "^0.2.1",
    "redis": "^5.11.0",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "fast-check": "^4.5.3",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
