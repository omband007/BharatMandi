# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bharat_mandi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# MongoDB Configuration (for future use)
MONGODB_URI=mongodb://localhost:27017/bharat_mandi

# Server Configuration
PORT=3000
NODE_ENV=development

# Hugging Face API (for AI grading)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# AWS Configuration (for Translation, Voice, and AI services)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# AWS Lex Configuration (for Kisan Mitra AI Assistant)
LEX_BOT_ID=your_lex_bot_id_here
LEX_BOT_ALIAS_ID=your_lex_bot_alias_id_here
LEX_REGION=ap-southeast-2

# Redis Configuration (for translation caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
